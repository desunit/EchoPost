<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= it.title %></title>
  <% if (it.canonicalUrl) { %><link rel="canonical" href="<%= it.canonicalUrl %>"><% } %>
  <meta name="description" content="<%= it.metaDescription || it.site.description %>">
  <meta property="og:title" content="<%= it.title %>">
  <meta property="og:description" content="<%= it.metaDescription || it.site.description %>">
  <meta property="og:type" content="<%= it.ogType || 'website' %>">
  <% if (it.canonicalUrl) { %><meta property="og:url" content="<%= it.canonicalUrl %>"><% } %>
  <meta property="og:image" content="<%= it.ogImage || it.defaultOgImage %>">
  <meta name="twitter:card" content="<%= it.ogImage ? 'summary_large_image' : 'summary' %>">
  <link rel="icon" type="image/jpeg" sizes="32x32" href="<%= it.base %>/assets/favicon-32x32.jpg">
  <link rel="icon" type="image/jpeg" sizes="192x192" href="<%= it.base %>/assets/favicon-192x192.jpg">
  <link rel="apple-touch-icon" href="<%= it.base %>/assets/apple-touch-icon.jpg">
  <link rel="alternate" type="application/rss+xml" title="<%= it.site.title %>" href="<%= it.base %>/rss">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400..700&family=IBM+Plex+Mono:wght@400;500&display=swap">
  <link rel="stylesheet" href="<%= it.base %>/assets/styles.css">
  <script src="<%= it.base %>/assets/theme.js"></script>
  <% if (it.admin) { %><script src="<%= it.base %>/assets/admin.js" defer></script><% } %>
  <meta name="theme-color" content="#fcfbf7" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#16140f" media="(prefers-color-scheme: dark)">
  <% if (it.jsonLd) { %><script type="application/ld+json"><%~ it.jsonLd %></script><% } %>
</head>
<body>
<header class="site-header">
  <nav>
    <a href="<%= it.base %>/" class="site-name"><% if (it.site.xUsername) { %>@<%= it.site.xUsername %><% } else { %><%= it.site.title %><% } %></a>
    <span class="nav-links">
      <a href="<%= it.base %>/tags">Tags</a>
      <a href="<%= it.base %>/stats">Stats</a>
      <a href="<%= it.base %>/search">Search</a>
      <a href="<%= it.base %>/rss">RSS</a>
      <% if (it.site.amaEnabled) { %><a href="<%= it.base %>/ama">Ask</a><% } %>
      <% if (it.admin) { %><a href="<%= it.base %>/admin">Admin</a><% } %>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle light/dark theme" title="Toggle theme">◐</button>
    </span>
  </nav>
</header>
<main>
<%~ it.body %>
</main>
<footer class="site-footer">
  <% if (it.site.customFooterHtml) { %><div><%~ it.site.customFooterHtml %></div><% } %>
  <p>
    <a href="<%= it.base %>/">Archive</a> · <a href="<%= it.base %>/tags">Tags</a> · <a href="<%= it.base %>/stats">Stats</a> · <a href="<%= it.base %>/rss">RSS</a>
    <% if (it.site.authorXUrl) { %> · <a href="<%= it.site.authorXUrl %>" rel="noopener">X</a><% } %>
  </p>
  <% if (it.totals) { %>
  <p class="muted">Total archive views: <%= it.formatNumber(it.totals.x + it.totals.blog) %>
    (<%= it.formatNumber(it.totals.x) %> on X · <%= it.formatNumber(it.totals.blog) %> on this site)</p>
  <% } %>
  <p class="muted">© 2026 powered by <a href="https://github.com/desunit/EchoPost" rel="noopener">EchoPost</a></p>
</footer>
</body>
</html>
