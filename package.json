{
  "name": "echopost",
  "version": "1.0.0",
  "description": "Personal content archive and X-to-blog mirror",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/scripts/migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "backup": "tsx src/scripts/backup.ts",
    "create-admin": "tsx src/scripts/create-admin.ts",
    "import-wordpress": "tsx src/scripts/import-wordpress.ts",
    "rewrite-media-base": "tsx src/scripts/rewrite-media-base.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/formbody": "^8.0.1",
    "@fastify/static": "^8.0.2",
    "better-sqlite3": "^11.7.0",
    "eta": "^3.5.0",
    "fastify": "^5.1.0",
    "marked": "^15.0.3",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "sanitize-html": "^2.13.1",
    "tsx": "^4.19.2",
    "turndown": "^7.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.13.0",
    "@types/turndown": "^5.0.6",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
